---
import { SITE_TITLE } from '../consts';
---

<header class="site-header">
	<div class="nav-wrap">
		<a class="brand" href="/">{SITE_TITLE}</a>
		<nav aria-label="Main navigation" class="internal-links">
			<a class="nav-link" href="/#tech">Tech Stack</a>
			<a class="nav-link" href="/#memo">備忘録</a>
			<a class="nav-link" href="/intro/">入門ページ</a>
		</nav>
		<div class="social-links">
			<a href="https://github.com/woruka" target="_blank" rel="noreferrer noopener">GitHub</a>
			<a href="https://x.com/sawanumaworuka" target="_blank" rel="noreferrer noopener">X</a>
		</div>
	</div>
</header>
<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(16px);
		background: rgba(var(--surface), 82%);
		border-bottom: 1px solid rgb(var(--gray-light));
	}

	.nav-wrap {
		width: min(1080px, calc(100% - 2rem));
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 0.8rem 0;
	}

	.brand {
		margin: 0;
		font-size: 1.08rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		color: rgb(var(--black));
		text-decoration: none;
	}

	nav {
		margin-left: auto;
	}

	.internal-links {
		display: flex;
		gap: 0.25rem;
		padding: 0.26rem;
		background: rgb(var(--surface-soft));
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
	}

	.internal-links .nav-link {
		padding: 0.36rem 0.85rem;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		border-radius: 999px;
		font-weight: 700;
		font-size: 0.86rem;
		letter-spacing: 0.02em;
	}

	.internal-links .nav-link:hover {
		color: #fff;
		background: var(--accent);
	}

	.social-links {
		display: flex;
		gap: 0.45rem;
	}

	.social-links a {
		padding: 0.32rem 0.72rem;
		text-decoration: none;
		font-size: 0.82rem;
		font-weight: 700;
		color: rgb(var(--gray-dark));
		background: rgba(var(--surface), 88%);
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
	}

	.social-links a:hover {
		border-color: rgba(var(--black), 22%);
	}

	@media (max-width: 800px) {
		.nav-wrap {
			width: calc(100% - 1rem);
			flex-wrap: wrap;
			justify-content: center;
			padding: 0.6rem 0;
		}

		nav {
			margin-left: 0;
		}

		.social-links {
			width: 100%;
			justify-content: center;
		}
	}
</style>
