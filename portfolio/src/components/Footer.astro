---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-wrap">
		<p class="copyright">&copy; {today.getFullYear()} woruka. All rights reserved.</p>
		<div class="social-links">
			<a href="https://github.com/woruka" target="_blank" rel="noreferrer noopener">GitHub</a>
			<a href="https://x.com/sawanumaworuka" target="_blank" rel="noreferrer noopener">X</a>
		</div>
	</div>
</footer>
<style>
	.site-footer {
		border-top: 1px solid rgb(var(--gray-light));
		background: rgba(var(--surface), 84%);
		backdrop-filter: blur(8px);
	}

	.footer-wrap {
		width: min(1080px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.2rem 0 1.4rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
	}

	.copyright {
		margin: 0;
		font-size: 0.84rem;
		color: rgb(var(--gray));
	}

	.social-links {
		display: flex;
		gap: 0.5rem;
	}

	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-size: 0.8rem;
		font-weight: 700;
		padding: 0.3rem 0.68rem;
		border-radius: 999px;
		border: 1px solid rgb(var(--gray-light));
		background: rgba(var(--surface), 88%);
	}

	.social-links a:hover {
		border-color: rgba(var(--black), 22%);
	}

	@media (max-width: 800px) {
		.footer-wrap {
			width: calc(100% - 1rem);
			flex-direction: column;
			text-align: center;
			padding: 1rem 0 1.2rem;
		}
	}
</style>
