---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { TECH_STATUS_META, TECH_STATUS_ORDER, techStacks } from '../../data/techStacks';

const groupedTechStacks = TECH_STATUS_ORDER.map((status) => ({
	status,
	meta: TECH_STATUS_META[status],
	items: techStacks.filter((stack) => stack.status === status && stack.visible),
})).filter((group) => group.items.length > 0);
---
<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`${SITE_TITLE} | 入門ページ`} description={SITE_DESCRIPTION} />
		<style>
			.intro-main {
				display: grid;
				gap: 1rem;
			}

			.card {
				padding: clamp(1.2rem, 3vw, 2rem);
				border-radius: 22px;
				border: 1px solid rgb(var(--gray-light));
				background: rgba(var(--surface), 84%);
				box-shadow: var(--box-shadow);
			}

			.group-grid {
				display: grid;
				gap: 0.8rem;
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}

			.group-card {
				padding: 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 14px;
				background: rgb(var(--surface-soft));
			}

			.group-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.6rem;
			}

			.group-head h2 {
				margin: 0;
				font-size: 1.1rem;
			}

			.count {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 1.8rem;
				height: 1.8rem;
				padding: 0 0.4rem;
				border-radius: 999px;
				font-size: 0.82rem;
				font-weight: 700;
				background: rgba(139, 58, 30, 12%);
				color: var(--accent);
			}

			.group-desc {
				margin: 0.55rem 0 0.75rem;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}

			.tech-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.45rem;
			}

			.tech-list a {
				display: block;
				padding: 0.65rem 0.75rem;
				border-radius: 10px;
				border: 1px solid rgb(var(--gray-light));
				background: rgba(var(--surface), 65%);
				text-decoration: none;
				color: rgb(var(--gray-dark));
				font-weight: 700;
			}

			.tech-list a:hover {
				background: var(--accent);
				border-color: var(--accent);
				color: #fff;
			}

			@media (max-width: 920px) {
				.group-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="intro-main">
			<section class="card">
				<h1>技術別 入門ページ</h1>
				<p>
					各技術の「まず何を触るか」を整理したページです。実務経験ありと学習中で分けて管理しています。
				</p>
			</section>
			<section class="group-grid">
				{
					groupedTechStacks.map((group) => (
						<article class="group-card">
							<div class="group-head">
								<h2>{group.meta.label}</h2>
								<span class="count">{group.items.length}</span>
							</div>
							<p class="group-desc">{group.meta.description}</p>
							<ul class="tech-list">
								{
									group.items.map((item) => (
										<li>
											<a href={`/intro/${item.slug}/`}>{item.name}</a>
										</li>
									))
								}
							</ul>
						</article>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
