---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { SITE_TITLE } from '../../consts';
import { TECH_STATUS_META, techStacks, type TechStack } from '../../data/techStacks';

export function getStaticPaths() {
	return techStacks.filter((tech) => tech.visible).map((tech) => ({
		params: { slug: tech.slug },
		props: { tech },
	}));
}

type Props = {
	tech: TechStack;
};

const { tech } = Astro.props as Props;
const statusMeta = TECH_STATUS_META[tech.status];
---

<SiteLayout
	title={`${SITE_TITLE} | ${tech.name} 入門`}
	description={tech.summary}
>
	<section class="surface-card">
		<div class="meta-row">
			<span class="meta-badge">{statusMeta.label}</span>
			<span class="meta-badge">{tech.category}</span>
		</div>
		<h1>{tech.name} 入門</h1>
		<p class="text-muted summary">{tech.summary}</p>
	</section>

	<section class="stack-grid-2">
		<article class="surface-card--soft panel">
			<h2>最初に覚えるポイント</h2>
			<ul>
				{tech.beginnerPoints.map((point) => <li>{point}</li>)}
			</ul>
		</article>
		<article class="surface-card--soft panel">
			<h2>最初の 3 ステップ</h2>
			<ul>
				{tech.firstSteps.map((step) => <li>{step}</li>)}
			</ul>
		</article>
	</section>

	{
		tech.roadmap && (
			<section class="surface-card--soft single-panel">
				<h2>学習ロードマップ</h2>
				<ol class="roadmap-list">
					{tech.roadmap.map((step) => <li><strong>{step.phase}</strong>{step.goal}</li>)}
				</ol>
			</section>
		)
	}

	{
		tech.resources && (
			<section class="surface-card--soft single-panel">
				<h2>参考リンク</h2>
				<ul class="resource-list">
					{
						tech.resources.map((resource) => (
							<li>
								<a href={resource.url} target="_blank" rel="noreferrer noopener">{resource.label}</a>
							</li>
						))
					}
				</ul>
			</section>
		)
	}

	<section class="surface-card">
		<div class="inline-link-row">
			<a href="/intro/">技術ページ一覧へ戻る</a>
			<a href="/#tech">Home の技術スタックへ戻る</a>
		</div>
	</section>

	<style>
		.meta-row {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			margin-bottom: 0.7rem;
		}

		.summary {
			margin: 0;
		}

		.panel h2 {
			margin: 0 0 0.55rem;
			font-size: 1.08rem;
		}

		.panel ul {
			margin: 0;
			padding-left: 1.1rem;
			display: grid;
			gap: 0.32rem;
		}

		.single-panel {
			padding: 1rem;
		}

		.roadmap-list {
			margin: 0;
			padding-left: 1rem;
			display: grid;
			gap: 0.5rem;
		}

		.roadmap-list strong {
			display: inline-block;
			margin-right: 0.35rem;
		}

		.resource-list {
			margin: 0;
			padding-left: 1rem;
			display: grid;
			gap: 0.38rem;
		}
	</style>
</SiteLayout>
