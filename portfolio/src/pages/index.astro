---
import FormattedDate from '../components/FormattedDate.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { learningSteps } from '../data/learningGuide';
import { memos } from '../data/memos';
import { TECH_STATUS_META, TECH_STATUS_ORDER, techStacks } from '../data/techStacks';

const sortedMemos = [...memos].sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
const featuredLearningSteps = learningSteps.slice(0, 3);
const groupedTechStacks = TECH_STATUS_ORDER.map((status) => ({
	status,
	meta: TECH_STATUS_META[status],
	items: techStacks.filter((stack) => stack.status === status && stack.visible),
})).filter((group) => group.items.length > 0);
---

<SiteLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="surface-card hero-card">
		<span class="section-pill">Mobile Engineer</span>
		<h1>woruka</h1>
		<p class="text-muted lead-copy">
			モバイル開発の実務と学習メモを整理するためのポートフォリオです。Flutter / Kotlin / Swift を軸に、セキュリティ、OSS、設計メモも少しずつ公開しています。
		</p>
	</section>

	<section id="learn" class="surface-card">
		<span class="section-pill">Learn</span>
		<h2>このサイトを教材として使う</h2>
		<p class="text-muted section-copy">
			Astro サイトを壊さずに学べるように、最初に触る 3 ファイルだけをここに出しています。詳しい手順は /learn/ にまとめています。
		</p>
		<div class="stack-grid-3 section-gap">
			{
				featuredLearningSteps.map((step) => (
					<article class="surface-card--soft learn-card">
						<span class="meta-badge">{step.path}</span>
						<h3>{step.title}</h3>
						<p class="text-muted">{step.summary}</p>
						<p><strong>変化:</strong> {step.visibleChange}</p>
					</article>
				))
			}
		</div>
		<p class="section-link">
			<a href="/learn/">学習ガイドを開く</a>
		</p>
	</section>

	<section id="tech" class="surface-card">
		<span class="section-pill">Tech Stack</span>
		<h2>技術スタック</h2>
		<p class="text-muted section-copy">
			実務経験ありと学習中を分けて整理しています。気になる技術は詳細ページから学習ステップまで確認できます。
		</p>
		<div class="stack-grid-2 section-gap">
			{
				groupedTechStacks.map((group) => (
					<article class="surface-card--soft stack-group-card">
						<div class="stack-group-head">
							<h3>{group.meta.label}</h3>
							<span class="stack-count">{group.items.length}</span>
						</div>
						<p class="text-muted stack-group-copy">{group.meta.description}</p>
						<ul class="stack-list">
							{
								group.items.map((item) => (
									<li>
										<a href={`/intro/${item.slug}/`}>{item.name}</a>
									</li>
								))
							}
						</ul>
					</article>
				))
			}
		</div>
		<p class="section-link">
			<a href="/intro/">技術別の入門ページ一覧を見る</a>
		</p>
	</section>

	<section id="memo" class="surface-card">
		<div class="section-head">
			<div>
				<span class="section-pill">Notes</span>
				<h2>備忘録</h2>
			</div>
			<span class="stack-count">{sortedMemos.length}</span>
		</div>
		{
			sortedMemos.length === 0 ? (
				<p class="memo-empty">
					まだ公開メモはありません。`src/data/memos.ts` に 1 件追加すると、ここにカードが表示されます。
				</p>
			) : (
				<ul class="memo-list">
					{
						sortedMemos.map((memo) => (
							<li class="memo-item">
								<article class="surface-card--soft memo-card">
									<p class="memo-date"><FormattedDate date={new Date(memo.date)} /></p>
									<h3>{memo.title}</h3>
									<p class="text-muted">{memo.summary}</p>
								</article>
							</li>
						))
					}
				</ul>
			)
		}
	</section>

	<style>
		.hero-card {
			padding-bottom: clamp(1.5rem, 3.4vw, 2.4rem);
		}

		.lead-copy {
			max-width: 44ch;
			margin: 0;
		}

		.section-copy {
			margin-bottom: 0;
		}

		.section-gap {
			margin-top: 1rem;
		}

		.section-link {
			margin: 1rem 0 0;
			font-size: 0.92rem;
		}

		.section-link a {
			font-weight: 700;
		}

		.learn-card h3,
		.stack-group-card h3,
		.memo-card h3 {
			margin-bottom: 0.45rem;
		}

		.learn-card p,
		.memo-card p {
			margin: 0;
		}

		.learn-card p + p {
			margin-top: 0.45rem;
		}

		.stack-group-head,
		.section-head {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 1rem;
		}

		.stack-group-copy {
			margin: 0.55rem 0 0.75rem;
			font-size: 0.92rem;
		}

		.stack-count {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 1.8rem;
			height: 1.8rem;
			padding: 0 0.45rem;
			border-radius: 999px;
			font-size: 0.86rem;
			font-weight: 700;
			background: rgba(139, 58, 30, 12%);
			color: var(--accent);
			border: 1px solid rgba(139, 58, 30, 20%);
		}

		.stack-list {
			list-style: none;
			display: flex;
			flex-wrap: wrap;
			gap: 0.4rem;
			margin: 0;
			padding: 0;
		}

		.stack-list li a {
			display: inline-flex;
			align-items: center;
			padding: 0.16rem 0.54rem;
			border-radius: 999px;
			font-size: 0.8rem;
			font-weight: 700;
			color: rgb(var(--gray-dark));
			background: rgba(196, 133, 96, 16%);
			border: 1px solid rgba(139, 58, 30, 22%);
			text-decoration: none;
		}

		.stack-list li a:hover {
			color: #fff;
			background: var(--accent);
			border-color: var(--accent);
		}

		.memo-empty {
			margin: 0;
			padding: 0.95rem 1rem;
			border-radius: 14px;
			border: 1px dashed rgba(139, 58, 30, 36%);
			background: rgba(139, 58, 30, 5%);
			font-size: 0.92rem;
			color: rgb(var(--gray));
		}

		.memo-list {
			list-style: none;
			margin: 1rem 0 0;
			padding: 0;
			display: grid;
			gap: 0.7rem;
		}

		.memo-date {
			margin: 0 0 0.28rem;
			font-size: 0.82rem;
			color: rgb(var(--gray));
		}
	</style>
</SiteLayout>
