---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { memos } from '../data/memos';
import { TECH_STATUS_META, TECH_STATUS_ORDER, techStacks } from '../data/techStacks';

const sortedMemos = [...memos].sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());
const groupedTechStacks = TECH_STATUS_ORDER.map((status) => ({
	status,
	meta: TECH_STATUS_META[status],
	items: techStacks.filter((stack) => stack.status === status && stack.visible),
})).filter((group) => group.items.length > 0);
---
<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.home {
				display: grid;
				gap: 1rem;
			}

			.card {
				padding: clamp(1.25rem, 3vw, 2.2rem);
				border-radius: 24px;
				border: 1px solid rgb(var(--gray-light));
				background: rgba(var(--surface), 84%);
				box-shadow: var(--box-shadow);
			}

			.hero {
				padding-bottom: clamp(1.5rem, 3.4vw, 2.4rem);
			}

			.eyebrow,
			.section-label {
				display: inline-block;
				margin-bottom: 0.8rem;
				padding: 0.2rem 0.6rem;
				font-size: 0.74rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--accent);
				background: rgba(139, 58, 30, 10%);
				border-radius: 999px;
			}

			.lead {
				max-width: 44ch;
				margin: 0;
				color: rgb(var(--gray));
			}

			.stack-summary {
				margin-bottom: 0.95rem;
				font-size: 0.95rem;
				color: rgb(var(--gray));
			}

			.stack-groups {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 0.85rem;
			}

			.stack-group-card {
				padding: 1rem;
				border-radius: 16px;
				border: 1px solid rgb(var(--gray-light));
				background: rgb(var(--surface-soft));
			}

			.stack-group-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.5rem;
				margin-bottom: 0.45rem;
			}

			.stack-group-card h3 {
				margin: 0;
				font-size: 1rem;
			}

			.stack-count {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 1.6rem;
				height: 1.6rem;
				padding: 0 0.4rem;
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--accent);
				background: rgba(139, 58, 30, 12%);
				border: 1px solid rgba(139, 58, 30, 20%);
				border-radius: 999px;
			}

			.stack-group-card p {
				margin: 0 0 0.7rem;
				font-size: 0.92rem;
				color: rgb(var(--gray));
			}

			.stack-list {
				list-style: none;
				display: flex;
				flex-wrap: wrap;
				gap: 0.4rem;
				margin: 0;
				padding: 0;
			}

			.stack-list li a {
				display: inline-flex;
				align-items: center;
				padding: 0.16rem 0.54rem;
				border-radius: 999px;
				font-size: 0.8rem;
				font-weight: 700;
				color: rgb(var(--gray-dark));
				background: rgba(196, 133, 96, 16%);
				border: 1px solid rgba(139, 58, 30, 22%);
				text-decoration: none;
			}

			.stack-list li a:hover {
				color: #fff;
				background: var(--accent);
				border-color: var(--accent);
			}

			.stack-guide-link {
				margin: 1rem 0 0;
				font-size: 0.92rem;
			}

			.stack-guide-link a {
				font-weight: 700;
			}

			.section-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 0.5rem;
			}

			.memo-count {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-width: 1.8rem;
				height: 1.8rem;
				padding: 0 0.45rem;
				border-radius: 999px;
				font-size: 0.86rem;
				font-weight: 700;
				background: rgba(139, 58, 30, 12%);
				color: var(--accent);
				border: 1px solid rgba(139, 58, 30, 20%);
			}

			.memo-empty {
				margin: 0;
				padding: 0.95rem 1rem;
				border-radius: 14px;
				border: 1px dashed rgba(139, 58, 30, 36%);
				background: rgba(139, 58, 30, 5%);
				font-size: 0.92rem;
				color: rgb(var(--gray));
			}

			.memo-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.7rem;
			}

			.memo-item article {
				padding: 0.9rem 1rem;
				border-radius: 14px;
				border: 1px solid rgb(var(--gray-light));
				background: rgba(var(--surface-soft), 72%);
			}

			.memo-date {
				margin: 0 0 0.28rem;
				font-size: 0.82rem;
				color: rgb(var(--gray));
			}

			.memo-item h3 {
				margin: 0 0 0.25rem;
				font-size: 1.08rem;
			}

			.memo-item p {
				margin: 0;
				font-size: 0.93rem;
				color: rgb(var(--gray));
			}

			@media (max-width: 920px) {
				.stack-groups {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="hero card">
				<span class="eyebrow">Mobile Engineer</span>
				<h1>woruka</h1>
				<p class="lead">
					入門学習の整理と実務メモを蓄積するためのポートフォリオです。
				</p>
			</section>
			<section id="tech" class="card">
				<span class="section-label">Tech Stack</span>
				<h2>技術スタック</h2>
				<p class="stack-summary">
					「実務経験あり」と「学習中」で分けて整理しています。各技術の入門ページへ移動できます。
				</p>
				<div class="stack-groups">
					{
						groupedTechStacks.map((group) => (
							<article class="stack-group-card">
								<div class="stack-group-head">
									<h3>{group.meta.label}</h3>
									<span class="stack-count">{group.items.length}</span>
								</div>
								<p>{group.meta.description}</p>
								<ul class="stack-list">
									{
										group.items.map((item) => (
											<li>
												<a href={`/intro/${item.slug}/`}>{item.name}</a>
											</li>
										))
									}
								</ul>
							</article>
						))
					}
				</div>
				<p class="stack-guide-link">
					<a href="/intro/">技術別の入門ページ一覧を見る</a>
				</p>
			</section>
			<section id="memo" class="card">
				<div class="section-head">
					<div>
						<span class="section-label">Notes</span>
						<h2>備忘録</h2>
					</div>
					<span class="memo-count">{sortedMemos.length}</span>
				</div>
				{
					sortedMemos.length === 0 ? (
						<p class="memo-empty">現在 0 件です。`src/data/memos.ts` に追加するとここへ表示されます。</p>
					) : (
						<ul class="memo-list">
							{
								sortedMemos.map((memo) => (
									<li class="memo-item">
										<article>
											<p class="memo-date"><FormattedDate date={new Date(memo.date)} /></p>
											<h3>{memo.title}</h3>
											<p>{memo.summary}</p>
										</article>
									</li>
								))
							}
						</ul>
					)
				}
			</section>
		</main>
		<Footer />
	</body>
</html>
